# Configuration Hermes Agent — ETS Maria (inférence API Mistral, egress scellé)
# À copier vers ~/.hermes/config.yaml (monté dans le conteneur hermes en `/opt/data`).
# Remplacer __CLE_API_GATEWAY__ par une clé aléatoire : openssl rand -hex 24
#
# Inférence : API Mistral (free tier) via l'egress-proxy allowlisté — seul
# domaine de sortie. mistral-small-latest = Mistral Small 3.2 (24B, Apache
# 2.0) : même modèle open-weights qu'un Mac mini M4 Pro 48 Go ferait tourner
# en local (cible d'achat). Tester la cible 24 Go : default: "open-mistral-nemo" (12B).
# Retour 100 % local (démo v1) : COMPOSE_PROFILES=local, puis provider:
# "ollama", base_url: "http://ollama:11434/v1", api_key: "ollama-local".

model:
  default: "mistral-small-latest"
  provider: "custom"                      # endpoint OpenAI-compatible générique
  base_url: "https://api.mistral.ai/v1"
  # PAS d'api_key ici : Hermes la dérive de l'env MISTRAL_API_KEY
  # (host-derived depuis base_url), injectée par docker-compose depuis .env.
  # Aucun secret dans ce fichier.
  context_length: 131072                  # fenêtre réelle de Mistral Small 3.2 (128K).
                                          # Hermes exige >= 64K — ne pas descendre en dessous.

# Tâches auxiliaires (compression de contexte, résumé de sessions) : tout sur
# l'endpoint principal (Mistral). Jamais un autre provider — UN seul domaine
# de sortie, celui de l'allowlist.
auxiliary:
  vision:
    provider: "main"
    model: ""
  web_extract:
    provider: "main"
    model: ""
  session_search:
    provider: "main"
    model: ""

compression:
  enabled: true
  threshold: 0.50

memory:
  memory_enabled: true                    # mémoire 100 % locale (SQLite + ~/.hermes/memories/)
  user_profile_enabled: true

stt:
  enabled: false                          # pas de vocal ; évite l'install lazy de faster-whisper

agent:
  max_turns: 10                           # boucle courte : usage purement rédactionnel
  verbose: false

# Toolsets par plateforme.
# api_server = ce que voient les employés via Open WebUI. Le CONTEXTE métier
# (client, devis, catalogue, mails) est injecté par le RAG natif d'Open WebUI,
# pas par un tool donné au modèle. On ne donne AUCUN tool web/file/terminal au
# modèle : un mail client collé peut contenir une injection de prompt.
# [] = zéro tool, zéro surface d'injection : les règles vivent dans SOUL.md.
# Élargissement maximal toléré : [skills, todo, memory] — et SEULEMENT si
# ~/.hermes/skills ne contient que les skills du projet (un ~/.hermes partagé
# avec un usage perso exposerait tous ses skills au modèle).
# Ne jamais élargir api_server à [terminal, file, web].
# cli = accès complet pour l'administrateur en local.
platform_toolsets:
  cli: [hermes-cli]
  api_server: []

platforms:
  api_server:
    enabled: true
    extra:
      key: "__CLE_API_GATEWAY__"
      host: "0.0.0.0"   # bind interne au conteneur (joignable par open-webui
                        # sur net_internal). Port NON publié + réseau sans
                        # egress => pas une exposition LAN.
      port: 8642
      model_name: "maria-agent"

display:
  compact: true
