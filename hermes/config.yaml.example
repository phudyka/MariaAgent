# Configuration Hermes Agent — ETS Maria (agent local hermétique)
# À copier vers ~/.hermes/config.yaml (home de l'utilisateur qui lance le gateway).
# Remplacer __CLE_API_GATEWAY__ par une clé aléatoire : openssl rand -hex 24
# Modèle servi par Ollama local. Aucun provider cloud configuré.

model:
  default: "qwen3:4b-instruct-2507-q4_K_M"
  provider: "ollama"                      # alias du provider "custom" (endpoint OpenAI-compatible)
  base_url: "http://127.0.0.1:11434/v1"
  api_key: "ollama-local"                 # Ollama n'authentifie pas ; le SDK exige une valeur non vide
  context_length: 65536                   # aligné sur OLLAMA_CONTEXT_LENGTH (KV q4_0 + flash attention) — minimum Hermes : 64k

providers:
  ollama-local:
    request_timeout_seconds: 300          # démarrage à froid du modèle (chargement VRAM/RAM)

# Tâches auxiliaires (compression de contexte, résumé de sessions) : tout sur
# l'endpoint local. Jamais OpenRouter/Nous Portal — contrainte hermétique.
auxiliary:
  vision:
    provider: "main"
    model: ""
  web_extract:
    provider: "main"
    model: ""
  session_search:
    provider: "main"
    model: ""

compression:
  enabled: true
  threshold: 0.50

memory:
  memory_enabled: true                    # mémoire 100 % locale (SQLite + ~/.hermes/memories/)
  user_profile_enabled: true

stt:
  enabled: false                          # pas de vocal ; évite l'install lazy de faster-whisper

agent:
  max_turns: 10                           # boucle courte : modèle 4B + usage rédactionnel
  verbose: false

# Toolsets par plateforme.
# api_server = ce que voient les employés via l'UI : AUCUN terminal, AUCUN accès
# fichier/web/navigateur. Un mail client copié-collé peut contenir des instructions
# hostiles (prompt injection) — la surface d'outils doit rester minimale.
# cli = accès complet pour l'administrateur en local.
platform_toolsets:
  cli: [hermes-cli]
  api_server: [skills, todo, memory]

platforms:
  api_server:
    enabled: true
    extra:
      key: "__CLE_API_GATEWAY__"
      host: "127.0.0.1"                   # jamais 0.0.0.0 : seul le proxy local y accède
      port: 8642
      model_name: "maria-agent"

display:
  compact: true
